@model IEnumerable<BookRecordApp.Models.BookRecord>

@{
	ViewData["Title"] = "Book Records";
}
<link rel="stylesheet" href="~/css/site.css" />
<body class="Index container py-4">

	<h1 class="mb-4 text-center fs-2">Book Records</h1>

	<div class="row mb-4 align-items-center">
		<div class="col-md-6 mb-3 mb-md-0 target-add-button">
			<a class="btn btn-primary px-4 py-2" asp-action="Create">Add new book</a>
		</div>
		<div class="col-md-6 text-md-end">
			<form asp-action="Index" method="get" class="d-flex w-100">
				<input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control me-2 shadow-sm" placeholder="Buscar por título ou autor..." />
				<button type="submit" class="btn btn-secondary shadow-sm px-4">Buscar</button>
			</form>
		</div>
	</div>
	<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-4">
		@foreach (var item in Model)
		{
			<div class="col">
				<div class="card h-100 shadow-sm border-0 bg-light">
					<div class="card-body">
						<h5 class="card-title text-primary fw-bold">@item.BookName</h5>
						<h6 class="card-subtitle mb-3 text-secondary">@item.AuthorName</h6>
						<p class="card-text mb-2">
							<span class="badge bg-info text-dark mb-2">@item.Status</span>
							@if(item.Rating.HasValue) {
								<span class="badge bg-warning text-dark mb-2">★ @item.Rating/5</span>
							}
							<br />
							<strong>Início:</strong> @item.StartDate?.ToString("dd/MM/yyyy")<br />
							<strong>Conclusão:</strong> @item.EndDate?.ToString("dd/MM/yyyy")<br />
							<strong>Vezes Lido:</strong> @item.Count
						</p>
					</div>
					<div class="card-footer bg-transparent border-0 pt-0">
						<div class="d-flex justify-content-between">
							<a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-warning btn-sm px-3">Editar</a>
							<a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm px-3">Detalhes</a>
							<a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm px-3">Deletar</a>
						</div>
					</div>
				</div>
			</div>
		}
	</div>
</body>